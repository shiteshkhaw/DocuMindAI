{
  "name": "documind-ai-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "DocuMind AI Document Intelligence SaaS Monorepo",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.1",
    "turbo": "^2.4.4"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.28.0"
}
