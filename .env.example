# ==========================================
# DocuMind AI Environment Configurations
# ==========================================

# 1. FRONTEND APP (Next.js 15)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
NEXT_PUBLIC_SENTRY_DSN=

# 2. BACKEND API (FastAPI)
DATABASE_URL=postgresql+asyncpg://neondb_owner:password@hostname/neondb
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]
MAX_FILE_SIZE_MB=10
EMBEDDING_PROVIDER=openai
VECTOR_STORE_PROVIDER=chroma
CHROMA_PERSIST_DIRECTORY=./chroma_db
JWT_SECRET=super-secret-key-for-dev
GOOGLE_CLIENT_ID=your_google_client_id_here

# 3. AI & DATABASE SERVICES
OPENAI_API_KEY=
GEMINI_API_KEY=
HF_API_KEY=
GROQ_API_KEY=
CHROMA_API_KEY=
CHROMA_TENANT=default
CHROMA_DATABASE=default_database

# 4. INFRASTRUCTURE SERVICES
UPSTASH_REDIS_URL=
UPSTASH_REDIS_REST_TOKEN=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=documind-vault
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
RESEND_API_KEY=
EMAIL_FROM=DocuMind AI <noreply@documind.ai>
DRAMATIQ_BROKER_URL=
